@page "/method/relaxation"

<Method Title="Relaxation Method">
    <LearnSection>
        <div class="mb-8 rounded-xl border border-red-100 bg-red-50/50 p-6">
            <div class="flex items-start gap-4">
                <div>
                    <p class="leading-relaxed text-gray-700">
                        The Relaxation method is an intuitive, iterative technique for solving systems of linear equations. Instead of relying on heavy matrix algebra, it treats the equations as a system of springs. It starts with a blank guess (usually all zeros) and systematically "relaxes" or reduces the largest error (residual) in the system step-by-step—like a mathematical game of Whack-A-Mole—until the entire system settles into the correct answer.
                    </p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
                <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">
                    Algorithm
                </h3>
                <ol class="list-decimal space-y-3 pl-4 text-sm text-gray-600">
                    <li>Rewrite equations to calculate errors (Residuals: R1, R2, R3) by moving all variables to the right side.</li>
                    <li>Identify the "main divisor" for each variable from the transposed diagonals.</li>
                    <li>Initialize running totals (x = y = z = 0) and calculate initial residuals.</li>
                    <li>Find the largest absolute residual among R1, R2, and R3.</li>
                    <li>Calculate the step increment by dividing the max residual by its corresponding main divisor.</li>
                    <li>Add the increment to the running total of that specific variable, recalculate all residuals, and repeat until errors approach zero.</li>
                </ol>
            </div>

            <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
                <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">
                    Trade-offs
                </h3>
                <div class="space-y-4">
                    <div>
                        <span class="mb-1 block text-xs font-bold text-green-600 uppercase">Advantages</span>
                        <p class="text-sm text-gray-600">Excellent for large, sparse systems (many zeros). It limits round-off error accumulation because the residuals are constantly recalculated from the true equations.</p>
                    </div>
                    <div class="h-px w-full bg-gray-100"></div>
                    <div>
                        <span class="mb-1 block text-xs font-bold text-red-500 uppercase">Disadvantages</span>
                        <p class="text-sm text-gray-600">Can be very slow to converge for highly coupled or ill-conditioned systems. Requires constant searching to find the maximum error at every single step.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="my-10 border-y border-gray-100 py-10">
            <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">Alternate Solution Table Format</h3>
            <div class="w-fit overflow-hidden rounded-sm border border-gray-100 bg-white">
                <table class="border-collapse tracking-tighter text-[10px] text-gray-500">
                    <thead class="border-b border-gray-100 bg-gray-50/50">
                        <tr>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">i</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">Operation</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">δx (div)</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">δy (div)</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">δz (div)</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">R1</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">R2</th>
                            <th class="px-8 py-2 text-center">R3</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="text-gray-600">
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">1</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">x=y=z=0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono font-bold">8</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">4</td>
                            <td class="px-8 py-2 text-center font-mono">5</td>
                        </tr>
                        <tr class="bg-gray-50/30 text-gray-600">
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">2</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">δx=8/8=1</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono font-bold text-red-600">1</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-mono">2</td>
                            <td class="px-8 py-2 text-center font-mono font-bold">4</td>
                        </tr>
                        @for (int i = 0; i < 3; i++)
                        {
                            <tr class="text-gray-400">
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="px-8 py-2 text-center italic">-</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8">
            <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-500 uppercase">
                Real-World Applications
            </h3>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-red-200 hover:shadow-md">
                    <div class="mb-2 text-red-600"><i class="fa-solid fa-bridge"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">Structural Analysis</h4>
                    <p class="text-xs text-gray-500">Calculating the distribution of loads and stress across massive truss networks in bridges and buildings.</p>
                </div>
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-red-200 hover:shadow-md">
                    <div class="mb-2 text-red-600"><i class="fa-solid fa-temperature-half"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">Heat Transfer</h4>
                    <p class="text-xs text-gray-500">Determining the steady-state temperature distribution across a grid or plate over time.</p>
                </div>
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-red-200 hover:shadow-md">
                    <div class="mb-2 text-red-600"><i class="fa-solid fa-water"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">Fluid Dynamics</h4>
                    <p class="text-xs text-gray-500">Solving complex pressure fields and flow rates through interconnected pipe networks.</p>
                </div>
            </div>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="rounded-xl bg-amber-50 p-6 text-amber-900">
                <h3 class="mb-2 text-xs font-bold tracking-widest uppercase opacity-70">
                    Fun Fact
                </h3>
                <p class="text-sm">
                    In the pre-computer era, entire rooms of human "calculators" would solve massive systems by hand using this method! They would pass grid calculations back and forth, slowly "relaxing" the numbers until the engineering problem was solved.
                </p>
            </div>

            <div class="rounded-xl border border-red-100 bg-white p-6">
                <h3 class="mb-2 text-xs font-bold tracking-widest text-red-600 uppercase">
                    Pro Tip
                </h3>
                <p class="text-sm text-gray-600">
                    For the Relaxation Method to converge reliably, your system should ideally be <strong>diagonally dominant</strong>—meaning the absolute largest coefficient in each equation sits on the main diagonal. If your system is struggling to converge or blowing up, try swapping your rows before you start!
                </p>
            </div>
        </div>
    </LearnSection>

    <SolveSection>
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
            
            <div class="mb-8 border-b border-gray-100 pb-6">
                <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-500 uppercase">System of Equations (3x3 Matrix)</h3>
                
                <div class="grid max-w-2xl grid-cols-5 gap-3">
                    <div class="text-center text-xs font-bold text-gray-400">x</div>
                    <div class="text-center text-xs font-bold text-gray-400">y</div>
                    <div class="text-center text-xs font-bold text-gray-400">z</div>
                    <div></div>
                    <div class="text-center text-xs font-bold text-gray-400">b</div>

                    <input @bind="A00" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <input @bind="A01" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <input @bind="A02" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <div class="flex items-center justify-center font-mono text-gray-400">=</div>
                    <input @bind="B0" type="number" class="w-full rounded border border-gray-300 bg-red-50 p-2 text-center font-mono text-sm font-bold focus:border-red-500 focus:outline-none" />

                    <input @bind="A10" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <input @bind="A11" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <input @bind="A12" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <div class="flex items-center justify-center font-mono text-gray-400">=</div>
                    <input @bind="B1" type="number" class="w-full rounded border border-gray-300 bg-red-50 p-2 text-center font-mono text-sm font-bold focus:border-red-500 focus:outline-none" />

                    <input @bind="A20" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <input @bind="A21" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <input @bind="A22" type="number" class="w-full rounded border border-gray-300 bg-gray-50 p-2 text-center font-mono text-sm focus:border-red-500 focus:outline-none" />
                    <div class="flex items-center justify-center font-mono text-gray-400">=</div>
                    <input @bind="B2" type="number" class="w-full rounded border border-gray-300 bg-red-50 p-2 text-center font-mono text-sm font-bold focus:border-red-500 focus:outline-none" />
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-8">
                <div class="flex items-center gap-4">
                    <label class="text-xs font-bold tracking-widest text-gray-500 uppercase">Max Iterations</label>
                    <input @bind="maxIterations" type="number" min="0" max="1000" placeholder="0 = Auto" class="w-24 border-b border-gray-300 bg-transparent py-1 text-center font-mono text-sm focus:border-red-600 focus:outline-none" />
                </div>
                
                @if (errorMsg != "")
                {
                    <div class="text-xs font-bold text-red-500">@errorMsg</div>
                }
            </div>

            <div class="mt-8 flex justify-end gap-4 border-t border-gray-100 pt-6">
                <button @onclick="LoadPptExample"
                        class="rounded-lg border border-red-200 bg-red-50 px-6 py-2.5 text-xs font-bold tracking-widest text-red-600 transition-all hover:bg-red-100">
                    EXAMPLE
                </button>
                <button @onclick="() => iterations.Clear()"
                        class="rounded-lg px-6 py-2.5 text-xs font-bold tracking-widest text-gray-500 transition-all hover:bg-gray-50 hover:text-gray-900">
                    CLEAR
                </button>
                <button @onclick="Calculate"
                        class="rounded-lg bg-slate-900 px-8 py-2.5 text-xs font-bold tracking-widest text-white shadow-md transition-all hover:bg-red-600 hover:shadow-lg active:translate-y-0.5">
                    CALCULATE
                </button>
            </div>
        </div>

        @if (iterations.Any())
        {
            <div class="animate-fade-in-up mt-8">
                <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-center text-sm">
                            <thead class="bg-gray-50 text-xs font-bold tracking-wider text-gray-500 uppercase">
                                <tr>
                                    <th class="px-4 py-4">i</th>
                                    <th class="px-4 py-4 text-left">Operation</th>
                                    <th class="px-4 py-4 text-red-600">δx (@(A00?.ToString() ?? "-"))</th>
                                    <th class="px-4 py-4 text-red-600">δy (@(A11?.ToString() ?? "-"))</th>
                                    <th class="px-4 py-4 text-red-600">δz (@(A22?.ToString() ?? "-"))</th>
                                    <th class="px-4 py-4">R1</th>
                                    <th class="px-4 py-4">R2</th>
                                    <th class="px-4 py-4">R3</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @foreach (var iter in iterations)
                                {
                                    <tr class="text-gray-700 transition-colors hover:bg-red-50/30">
                                        <td class="px-4 py-3 font-mono text-gray-400">@iter.Iteration</td>
                                        <td class="px-4 py-3 text-left font-mono text-xs">@iter.Operation</td>
                                        
                                        <td class="px-4 py-3 font-mono @(iter.ChangedVar == "x" ? "font-bold text-red-600" : "")">@iter.X.ToString("0.0000")</td>
                                        <td class="px-4 py-3 font-mono @(iter.ChangedVar == "y" ? "font-bold text-red-600" : "")">@iter.Y.ToString("0.0000")</td>
                                        <td class="px-4 py-3 font-mono @(iter.ChangedVar == "z" ? "font-bold text-red-600" : "")">@iter.Z.ToString("0.0000")</td>
                                        
                                        <td class="px-4 py-3 font-mono @(iter.TargetResidualIndex == 1 ? "bg-amber-100 font-bold text-amber-900" : "")">@iter.R1.ToString("0.0000")</td>
                                        <td class="px-4 py-3 font-mono @(iter.TargetResidualIndex == 2 ? "bg-amber-100 font-bold text-amber-900" : "")">@iter.R2.ToString("0.0000")</td>
                                        <td class="px-4 py-3 font-mono @(iter.TargetResidualIndex == 3 ? "bg-amber-100 font-bold text-amber-900" : "")">@iter.R3.ToString("0.0000")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </SolveSection>
</Method>

@code {
    private double? A00, A01, A02, B0;
    private double? A10, A11, A12, B1;
    private double? A20, A21, A22, B2;

    private int maxIterations = 0;
    private readonly double DEFAULT_TOLERANCE = 0.0001;
    private string errorMsg = "";

    private List<RelaxationIteration> iterations = new();

    private void LoadPptExample()
    {
        A00 = 8; A01 = 1; A02 = 1; B0 = 8;
        A10 = 2; A11 = 4; A12 = 1; B1 = 4;
        A20 = 1; A21 = 3; A22 = 5; B2 = 5;
        
        maxIterations = 0; // Default auto-run
        iterations.Clear();
        errorMsg = "";
    }

    private void Calculate()
    {
        iterations.Clear();
        errorMsg = "";

        // Check if any inputs are null
        if (!A00.HasValue || !A01.HasValue || !A02.HasValue || !B0.HasValue ||
            !A10.HasValue || !A11.HasValue || !A12.HasValue || !B1.HasValue ||
            !A20.HasValue || !A21.HasValue || !A22.HasValue || !B2.HasValue)
        {
            errorMsg = "Please fill in all matrix values before calculating.";
            return;
        }

        double a00 = A00.Value, a01 = A01.Value, a02 = A02.Value, b0 = B0.Value;
        double a10 = A10.Value, a11 = A11.Value, a12 = A12.Value, b1 = B1.Value;
        double a20 = A20.Value, a21 = A21.Value, a22 = A22.Value, b2 = B2.Value;

        // Ensure diagonals are not zero
        if (a00 == 0 || a11 == 0 || a22 == 0)
        {
            errorMsg = "Main diagonal divisors cannot be zero. Please rearrange your equations.";
            return;
        }

        double x = 0, y = 0, z = 0;
        
        // Initial Residuals
        double r1 = Math.Round(b0 - (a00 * x) - (a01 * y) - (a02 * z), 4);
        double r2 = Math.Round(b1 - (a10 * x) - (a11 * y) - (a12 * z), 4);
        double r3 = Math.Round(b2 - (a20 * x) - (a21 * y) - (a22 * z), 4);

        iterations.Add(new RelaxationIteration
        {
            Iteration = 1,
            Operation = "x=y=z=0",
            ChangedVar = "",
            X = x,
            Y = y,
            Z = z,
            R1 = r1,
            R2 = r2,
            R3 = r3,
            TargetResidualIndex = GetMaxResidualIndex(r1, r2, r3)
        });

        // If maxIterations is 0, we rely strictly on the tolerance. We use 100 as a safety net to prevent browser crash.
        int loopLimit = maxIterations > 0 ? maxIterations : 100;

        for (int i = 2; i <= loopLimit + 1; i++)
        {
            var prev = iterations.Last();
            
            // Check Convergence using the default threshold
            double maxAbsR = Math.Max(Math.Abs(prev.R1), Math.Max(Math.Abs(prev.R2), Math.Abs(prev.R3)));
            if (maxAbsR < DEFAULT_TOLERANCE) break;

            string op = "";
            string changedVar = "";
            int target = prev.TargetResidualIndex;
            
            // Apply the Relaxation Step based on the targeted residual
            if (target == 1)
            {
                double inc = Math.Round(prev.R1 / a00, 4);
                x = Math.Round(x + inc, 4);
                op = $"δx={prev.R1.ToString("0.####")}/{a00}={inc.ToString("0.####")}";
                changedVar = "x";
            }
            else if (target == 2)
            {
                double inc = Math.Round(prev.R2 / a11, 4);
                y = Math.Round(y + inc, 4);
                op = $"δy={prev.R2.ToString("0.####")}/{a11}={inc.ToString("0.####")}";
                changedVar = "y";
            }
            else
            {
                double inc = Math.Round(prev.R3 / a22, 4);
                z = Math.Round(z + inc, 4);
                op = $"δz={prev.R3.ToString("0.####")}/{a22}={inc.ToString("0.####")}";
                changedVar = "z";
            }

            // Recalculate ALL residuals with the new variables
            r1 = Math.Round(b0 - (a00 * x) - (a01 * y) - (a02 * z), 4);
            r2 = Math.Round(b1 - (a10 * x) - (a11 * y) - (a12 * z), 4);
            r3 = Math.Round(b2 - (a20 * x) - (a21 * y) - (a22 * z), 4);

            iterations.Add(new RelaxationIteration
            {
                Iteration = i,
                Operation = op,
                ChangedVar = changedVar,
                X = x,
                Y = y,
                Z = z,
                R1 = r1,
                R2 = r2,
                R3 = r3,
                TargetResidualIndex = GetMaxResidualIndex(r1, r2, r3)
            });
        }
    }

    private int GetMaxResidualIndex(double r1, double r2, double r3)
    {
        double abs1 = Math.Abs(r1);
        double abs2 = Math.Abs(r2);
        double abs3 = Math.Abs(r3);

        if (abs1 >= abs2 && abs1 >= abs3) return 1;
        if (abs2 >= abs1 && abs2 >= abs3) return 2;
        return 3;
    }

    public class RelaxationIteration
    {
        public int Iteration { get; set; }
        public string Operation { get; set; } = "";
        public string ChangedVar { get; set; } = "";
        public double X { get; set; }
        public double Y { get; set; }
        public double Z { get; set; }
        public double R1 { get; set; }
        public double R2 { get; set; }
        public double R3 { get; set; }
        public int TargetResidualIndex { get; set; }
    }
}