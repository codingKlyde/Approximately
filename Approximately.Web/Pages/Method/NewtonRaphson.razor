@inject IToastService ToastService
@page "/method/newton-raphson"


<Method Title="Newton-Raphson Method">
    <LearnSection>
        <div class="mb-8 rounded-xl border border-blue-100 bg-blue-50/50 p-6">
            <div class="flex items-start gap-4">
                <div>
                    <p class="leading-relaxed text-gray-700">
                        Perhaps the most widely used of all root-locating formulas is the Newton-Raphson method. If the initial guess at the root is xi, a tangent line can be extended from the point [xi, f(xi)] down to the x-axis. The point where this tangent crosses the x-axis represents an improved estimate of the root.
                    </p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
                <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">
                    Algorithm
                </h3>
                <ol class="list-decimal space-y-3 pl-4 text-sm text-gray-600">
                    <li>Find points a and b such that a is less than b and f(a) * f(b) is less than 0.</li>
                    <li>Take the interval [a, b] and find the next value (initial guess) x0 = (a + b) / 2.</li>
                    <li>Find f(x0) and the derivative f'(x0).</li>
                    <li>Calculate the next estimate x1 = x0 - ( f(x0) / f'(x0) ).</li>
                    <li>If f(x1) = 0 then x1 is an exact root, else set x0 = x1.</li>
                    <li>Repeat steps 3 and 4 until f(x1) = 0 or the accuracy threshold is met.</li>
                </ol>
            </div>

            <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
                <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">
                    Trade-offs
                </h3>
                <div class="space-y-4">
                    <div>
                        <span class="mb-1 block text-xs font-bold text-green-600 uppercase">Advantages</span>
                        <p class="text-sm text-gray-600">Highly efficient. It exhibits <strong>quadratic convergence</strong>, meaning the number of significant figures of accuracy approximately doubles with each iteration.</p>
                    </div>
                    <div class="h-px w-full bg-gray-100"></div>
                    <div>
                        <span class="mb-1 block text-xs font-bold text-red-500 uppercase">Disadvantages</span>
                        <p class="text-sm text-gray-600">A near-zero slope (f'(x) approximately 0) is a disaster because it causes division by zero in the formula, flinging the solution infinitely far away. It can also endlessly oscillate around local maximums or minimums.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="my-10 border-y border-gray-100 py-10">
            <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">Manual Table Calculation Guide</h3>
            <div class="w-fit overflow-hidden rounded-sm border border-gray-100 bg-white">
                <table class="border-collapse tracking-tighter text-[10px] text-gray-500">
                    <thead class="border-b border-gray-100 bg-gray-50/50">
                        <tr>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">xi</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">f(xi)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="text-gray-400">
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">Initial x0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">f(x0)</td>
                        </tr>
                        @for (int i = 2; i <= 5; i++)
                        {
                            <tr class="text-gray-400">
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">@i</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">Calculated xi</td>
                                <td class="border-r border-gray-100 px-8 py-2 text-center italic">-</td>
                                <td class="px-8 py-2 text-center italic">-</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-8">
            <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-500 uppercase">
                Real-World Applications
            </h3>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-blue-200 hover:shadow-md">
                    <div class="mb-2 text-blue-600"><i class="fa-solid fa-microchip"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">Computer Graphics</h4>
                    <p class="text-xs text-gray-500">Famously used in the Quake III engine's "Fast Inverse Square Root" algorithm to rapidly compute lighting and reflection angles.</p>
                </div>
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-blue-200 hover:shadow-md">
                    <div class="mb-2 text-blue-600"><i class="fa-solid fa-satellite"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">GPS Navigation</h4>
                    <p class="text-xs text-gray-500">Employed to rapidly solve non-linear multi-dimensional intersection equations of satellite spheres to pinpoint coordinates.</p>
                </div>
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-blue-200 hover:shadow-md">
                    <div class="mb-2 text-blue-600"><i class="fa-solid fa-robot"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">Machine Learning</h4>
                    <p class="text-xs text-gray-500">Forms the foundation for advanced optimization algorithms (like Quasi-Newton methods) used to minimize loss functions when training AI models.</p>
                </div>
            </div>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="rounded-xl bg-amber-50 p-6 text-amber-900">
                <h3 class="mb-2 text-xs font-bold tracking-widest uppercase opacity-70">
                    Fun Fact
                </h3>
                <p class="text-sm">
                    The error in Newton-Raphson is roughly proportional to the square of the previous error (E_new is proportional to E_old squared). This means if your guess is accurate to 2 decimal places on iteration one, it will jump to 4 places on iteration two, and 8 places on iteration three!
                </p>
            </div>

            <div class="rounded-xl border border-blue-100 bg-white p-6">
                <h3 class="mb-2 text-xs font-bold tracking-widest text-blue-600 uppercase">
                    Pro Tip
                </h3>
                <p class="text-sm text-gray-600">
                    There is no general convergence criterion for Newton-Raphson. Its success depends entirely on the nature of the function and how close your initial guess is to the true root. Always graph your function first if possible to pick a safe starting point.
                </p>
            </div>
        </div>

        <div class="mt-12 border-t border-gray-100 pt-6">
            <h3 class="mb-4 font-bold tracking-widest text-[10px] text-gray-400 uppercase">References</h3>
            <ul class="space-y-2 text-xs text-gray-500">
                <li>Chapra, S. C., & Canale, R. P. (2015). <em>Numerical Methods for Engineers</em> (7th ed.). McGraw-Hill Education.</li>
            </ul>
        </div>
    </LearnSection>

    <SolveSection>
        @* --- INPUT AREA --- *@
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
            <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
                @* Function & Derivative Inputs *@
                <div class="space-y-6 md:col-span-2">
                    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                        <div class="space-y-2">
                            <label class="block text-xs font-bold tracking-widest text-gray-500 uppercase">
                                Target Function <span class="text-red-400">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute top-1/2 left-0 -translate-y-1/2 font-mono text-gray-400">f(x)=</span>
                                <input @bind="functionInput" placeholder="e.g. x^3 + 2x - 2"
                                       class="w-full border-b border-gray-200 bg-transparent py-2 pl-12 font-mono text-lg text-gray-900 focus:border-blue-600 focus:outline-none" />
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="block text-xs font-bold tracking-widest text-gray-500 uppercase">
                                Derivative <span class="text-red-400">*</span>
                            </label>
                            <div class="relative">
                                <span class="absolute top-1/2 left-0 -translate-y-1/2 font-mono text-gray-400">f'(x)=</span>
                                <input @bind="derivativeInput" placeholder="e.g. 3x^2 + 2"
                                       class="w-full border-b border-gray-200 bg-transparent py-2 pl-12 font-mono text-lg text-gray-900 focus:border-blue-600 focus:outline-none" />
                            </div>
                        </div>
                    </div>
                    <p class="text-[10px] text-gray-400">Supported: sin, cos, tan, log, exp, ^</p>
                </div>

                @* Settings & Guess *@
                <div class="space-y-6 md:border-l md:border-gray-100 md:pl-8">
                    <div class="space-y-2">
                        <label class="block text-xs font-bold tracking-widest text-gray-500 uppercase">
                            Initial Guess <span class="text-red-400">*</span>
                        </label>
                        <input @bind="x0Input" type="number" placeholder="e.g. 0"
                               class="w-full border-b border-gray-200 bg-transparent py-2 text-center font-mono text-lg text-gray-900 focus:border-blue-600 focus:outline-none" />
                    </div>

                    <div class="space-y-4 pt-2">
                        <div class="flex items-center justify-between gap-4">
                            <div class="flex items-center gap-2">
                                <input type="checkbox" @bind="UseIterationLimit" id="iterCheck"
                                       class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                                <label for="iterCheck" class="cursor-pointer text-xs font-bold text-gray-600 uppercase">Max Iterations</label>
                            </div>
                            <input @bind="totalIteration" type="number" disabled="@(!UseIterationLimit)"
                                   class="w-20 border-b border-gray-200 bg-transparent py-1 text-right font-mono text-sm focus:border-blue-600 focus:outline-none disabled:text-gray-200" />
                        </div>
                    </div>
                </div>
            </div>

            @* --- ACTION BUTTONS --- *@
            <div class="mt-10 flex justify-end gap-4 border-t border-gray-100 pt-6">
                <button @onclick="() => iterations.Clear()"
                        class="rounded-lg px-6 py-2.5 text-xs font-bold tracking-widest text-gray-500 transition-all hover:bg-gray-50 hover:text-gray-900">
                    CLEAR
                </button>
                <button @onclick="Calculate"
                        class="rounded-lg bg-slate-900 px-8 py-2.5 text-xs font-bold tracking-widest text-white shadow-md transition-all hover:bg-blue-600 hover:shadow-lg active:translate-y-0.5">
                    CALCULATE
                </button>
            </div>
        </div>

        @* --- RESULTS AREA --- *@
        @if (iterations.Any())
        {
            <div class="animate-fade-in-up mt-8">
                <div class="mb-4 flex items-center gap-4 text-xs text-gray-500">
                    <div class="rounded bg-gray-100 px-2 py-1 font-mono">f(x0) = @firstFaFormula</div>
                    <div class="rounded bg-gray-100 px-2 py-1 font-mono">f'(x0) = @firstDfFormula</div>
                </div>

                @{
                    var last = iterations.Last();
                    bool exactRootFoundInTable = false;
                }

                <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="min-w-full text-center text-sm">
                            <thead class="bg-gray-50 text-xs font-bold tracking-wider text-gray-500 uppercase">
                                <tr>
                                    <th class="px-6 py-4">i</th>
                                    <th class="px-6 py-4 text-blue-600">xi</th>
                                    <th class="px-6 py-4 font-bold text-gray-800">f(xi)</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @foreach (var iter in iterations)
                                {
                                    // Newton-Raphson stops when f(xi) is exactly 0 (or practically 0 based on screen formatting)
                                    bool isExactRoot = Math.Abs(iter.Fxi) < 0.0001;
                                    bool isLastRow = iter.Index == last.Index;

                                    bool isHighlight = (isExactRoot && !exactRootFoundInTable) || (!exactRootFoundInTable && isLastRow && !stoppedByZeroDiv);

                                    if (isExactRoot) exactRootFoundInTable = true;

                                    <tr class="transition-colors hover:bg-blue-50/30 @(isHighlight ? "bg-blue-600 text-white hover:bg-blue-700" : "text-gray-600")">
                                        <td class="px-6 py-3 font-mono">@iter.Index</td>
                                        <td class="px-6 py-3 font-mono font-bold @(isHighlight ? "text-white" : "text-blue-600")">@iter.Xi.ToString("0.####")</td>
                                        <td class="px-6 py-3 font-mono font-bold">@iter.Fxi.ToString("0.####")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* Result Summary Footer *@
                @if (stoppedByZeroDiv)
                {
                    <div class="mt-4 flex items-center gap-3 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
                        <i class="fa-solid fa-circle-exclamation text-red-500"></i>
                        <span class="text-sm font-medium">
                            Iteration stopped early. The derivative f'(x) evaluated to zero, which caused a Division by Zero error. Try a different initial guess.
                        </span>
                    </div>
                }
                else if (!exactRootFoundInTable && UseIterationLimit)
                {
                    <div class="mt-4 flex items-center gap-3 rounded-lg border border-amber-200 bg-amber-50 p-4 text-amber-800">
                        <i class="fa-solid fa-triangle-exclamation text-amber-500"></i>
                        <span class="text-sm font-medium">Stopped due to iteration limit. The highlighted root is approximate.</span>
                    </div>
                }
            </div>
        }
    </SolveSection>
</Method>


@code {
    private string functionInput = "";
    private string derivativeInput = "";
    private string firstFaFormula = "";
    private string firstDfFormula = "";
    private double? x0Input;

    private int totalIteration = 10;
    private List<IterationResult> iterations = new();

    private bool UseIterationLimit { get; set; } = true;
    private bool stoppedByZeroDiv = false;

    private double EvaluateMath(string rawExpression, double xValue, out string formulaDisplay)
    {
        try
        {
            string exprString = rawExpression.ToLower()
                .Replace("sin", "Sin")
                .Replace("cos", "Cos")
                .Replace("tan", "Tan")
                .Replace("log", "Log10")
                .Replace("ln", "Log")
                .Replace("exp", "Exp");

            // Fix implicit multiplication (e.g., 2x -> 2*x)
            exprString = Regex.Replace(exprString, @"(\d)(x)", "$1*$2");
            exprString = Regex.Replace(exprString, @"(\d)(\()", "$1*$2");

            // Fix exponent syntax
            if (exprString.Contains("^"))
                exprString = Regex.Replace(exprString, @"([a-zA-Z0-9\.]+)\^([a-zA-Z0-9\.\-]+)", "Pow($1, $2)");

            // Append .0 to standalone integers to prevent integer division zeroing out the formula
            exprString = Regex.Replace(exprString, @"(?<![a-zA-Z0-9_\.])(\d+)(?![a-zA-Z0-9_\.])", "$1.0");

            var expression = new NCalc.Expression(exprString);
            expression.Parameters["x"] = xValue;

            string xStr = xValue.ToString("G6", CultureInfo.InvariantCulture);
            formulaDisplay = rawExpression.Replace("x", $"({xStr})");

            var result = expression.Evaluate();
            return Convert.ToDouble(result);
        }
        catch
        {
            formulaDisplay = "Error";
            return 0;
        }
    }

    private void Calculate()
    {
        if (string.IsNullOrWhiteSpace(functionInput) || string.IsNullOrWhiteSpace(derivativeInput) || !x0Input.HasValue)
        {
            ToastService.ShowError("Please enter a function, a derivative, and an initial guess.");
            return;
        }

        iterations.Clear();
        stoppedByZeroDiv = false;
        double xCurr = x0Input.Value;

        try
        {
            bool keepIterating = true;
            int i = 1;

            while (keepIterating)
            {
                if (UseIterationLimit && i > totalIteration)
                {
                    break;
                }

                // Evaluate current point
                double fCurr = EvaluateMath(functionInput, xCurr, out string fDisp);
                double dfCurr = EvaluateMath(derivativeInput, xCurr, out string dfDisp);

                if (i == 1)
                {
                    firstFaFormula = fDisp;
                    firstDfFormula = dfDisp;
                }

                iterations.Add(new IterationResult
                {
                    Index = i,
                    Xi = xCurr,
                    Fxi = fCurr
                });

                // STOPPING LOGIC
                bool rootFound = Math.Abs(fCurr) < 0.0001;
                bool stopByIter = UseIterationLimit && i >= totalIteration;

                if (Math.Abs(dfCurr) < 1e-15 && !rootFound)
                {
                    stoppedByZeroDiv = true;
                    keepIterating = false;
                }
                else if (UseIterationLimit && stopByIter)
                {
                    keepIterating = false;
                }
                else if (rootFound)
                {
                    keepIterating = false;
                }
                else if (!UseIterationLimit && i >= 1000)
                {
                    keepIterating = false;
                }

                if (i >= 5000) keepIterating = false;

                // Newton-Raphson Formula
                if (!stoppedByZeroDiv)
                    xCurr = xCurr - (fCurr / dfCurr);

                i++;
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Check your formula format: {ex.Message}");
        }
    }

    public class IterationResult
    {
        public int Index { get; set; }
        public double Xi { get; set; }
        public double Fxi { get; set; }
    }
}