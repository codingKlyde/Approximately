@inject IToastService ToastService
@page "/method/gauss-jacobi"


<Method Title="Gauss-Jacobi Method">
    <LearnSection>
        <div class="mb-8 rounded-xl border border-blue-100 bg-blue-50/50 p-6">
            <div class="flex items-start gap-4">
                <div>
                    <p class="leading-relaxed text-gray-700">
                        The Gauss-Jacobi method is an iterative solver for linear systems. It uses the exact same rearranged equations and initial guesses as Gauss-Seidel. The defining difference is its strict update rule: Jacobi computes all new variables for the current iteration using <em>only</em> the data from the previous iteration.
                    </p>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
                <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">
                    Algorithm
                </h3>
                <ol class="list-decimal space-y-3 pl-4 text-sm text-gray-600">
                    <li>Rearrange the equations to solve for x1, x2, and x3.</li>
                    <li>Set an initial guess for all variables, typically zeros.</li>
                    <li>Construct a table and use the equations to calculate the new values.</li>
                    <li><strong>Crucial Rule:</strong> Calculate the entire row using ONLY the values from the previous iteration. Do not substitute newly found values until the next iteration begins!</li>
                    <li>Continue the process until the values stabilize and stop changing between iterations.</li>
                </ol>
            </div>

            <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
                <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">
                    Trade-offs
                </h3>
                <div class="space-y-4">
                    <div>
                        <span class="mb-1 block text-xs font-bold text-green-600 uppercase">Advantages</span>
                        <p class="text-sm text-gray-600">Highly parallelizable! Because x1, x2, and x3 only depend on old data, a modern multi-core computer can calculate all three equations at the exact same time.</p>
                    </div>
                    <div class="h-px w-full bg-gray-100"></div>
                    <div>
                        <span class="mb-1 block text-xs font-bold text-red-500 uppercase">Disadvantages</span>
                        <p class="text-sm text-gray-600">It is significantly slower to converge than Gauss-Seidel (often taking almost twice as many iterations). It also requires more computer memory since you must temporarily store both the "old" row and the "new" row.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="my-10 border-y border-gray-100 py-10">
            <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-900 uppercase">Manual Table Calculation Guide</h3>
            <div class="w-fit overflow-hidden rounded-sm border border-gray-100 bg-white">
                <table class="border-collapse tracking-tighter text-[10px] text-gray-500">
                    <thead class="border-b border-gray-100 bg-gray-50/50">
                        <tr>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">Iter</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">x1</th>
                            <th class="border-r border-gray-100 px-8 py-2 text-center">x2</th>
                            <th class="px-8 py-2 text-center">x3</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="text-gray-400">
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-bold text-gray-600">0</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center font-bold text-gray-600">0</td>
                            <td class="px-8 py-2 text-center font-bold text-gray-600">0</td>
                        </tr>
                        <tr class="text-gray-400">
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">1</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">Uses Iter 0 data</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">Uses Iter 0 data</td>
                            <td class="px-8 py-2 text-center italic">Uses Iter 0 data</td>
                        </tr>
                        <tr class="text-gray-400">
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">2</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">Uses Iter 1 data</td>
                            <td class="border-r border-gray-100 px-8 py-2 text-center italic">Uses Iter 1 data</td>
                            <td class="px-8 py-2 text-center italic">Uses Iter 1 data</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="mt-3 text-[10px] text-gray-400">Note: Every calculation in an iteration relies strictly on the row above it.</p>
        </div>

        <div class="mt-8">
            <h3 class="mb-4 text-xs font-bold tracking-widest text-gray-500 uppercase">
                Real-World Applications
            </h3>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-blue-200 hover:shadow-md">
                    <div class="mb-2 text-blue-600"><i class="fa-solid fa-microchip"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">GPU Rendering</h4>
                    <p class="text-xs text-gray-500">Because Jacobi is perfectly parallelizable, graphics cards use it to solve massive physical lighting simulations simultaneously across thousands of cores.</p>
                </div>
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-blue-200 hover:shadow-md">
                    <div class="mb-2 text-blue-600"><i class="fa-solid fa-image"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">Image Processing</h4>
                    <p class="text-xs text-gray-500">Image blurring and smoothing filters use Jacobi-style neighbor averaging to calculate the new color of every pixel at once.</p>
                </div>
                <div class="rounded-lg border border-gray-100 bg-white p-4 transition-all hover:border-blue-200 hover:shadow-md">
                    <div class="mb-2 text-blue-600"><i class="fa-solid fa-wind"></i></div>
                    <h4 class="mb-1 text-sm font-bold text-gray-900">Finite Difference Methods</h4>
                    <p class="text-xs text-gray-500">Used to solve differential equations on 3D grids, such as mapping heat diffusion or aerodynamics over an airplane wing.</p>
                </div>
            </div>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="rounded-xl bg-amber-50 p-6 text-amber-900">
                <h3 class="mb-2 text-xs font-bold tracking-widest uppercase opacity-70">
                    Fun Fact
                </h3>
                <p class="text-sm">
                    Even though Gauss-Seidel is generally preferred for normal calculations because it's faster, Gauss-Jacobi has made a massive comeback in the modern era! Because we now have supercomputers and GPUs with thousands of independent cores, Jacobi's "parallel" nature makes it faster on modern hardware than Seidel's "sequential" nature.
                </p>
            </div>

            <div class="rounded-xl border border-blue-100 bg-white p-6">
                <h3 class="mb-2 text-xs font-bold tracking-widest text-blue-600 uppercase">
                    Pro Tip
                </h3>
                <p class="text-sm text-gray-600">
                    Just like Gauss-Seidel, the Gauss-Jacobi method requires your equations to be <strong>Diagonally Dominant</strong> to guarantee convergence. If your iteration table is exploding to infinity, check the original matrix and swap the rows so the largest numbers are resting on the diagonal!
                </p>
            </div>
        </div>

        <div class="mt-12 border-t border-gray-100 pt-6">
            <h3 class="mb-4 font-bold tracking-widest text-[10px] text-gray-400 uppercase">References</h3>
            <ul class="space-y-2 text-xs text-gray-500">
                <li>Chapra, S. C., & Canale, R. P. (2015). <em>Numerical Methods for Engineers</em> (7th ed.). McGraw-Hill Education.</li>
            </ul>
        </div>
    </LearnSection>
    
<SolveSection>
        @* --- INPUT AREA --- *@
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
            <div class="mb-6 flex items-center justify-between">
                <label class="block text-xs font-bold tracking-widest text-gray-500 uppercase">
                    System of Equations (3x3) <span class="text-red-400">*</span>
                </label>
                <button @onclick="LoadExample" class="font-bold tracking-wider text-[10px] text-blue-600 uppercase hover:underline">
                    Load Slide Example
                </button>
            </div>

            <div class="overflow-x-auto">
                <div class="grid min-w-[600px] grid-cols-4 gap-4">
                    @* Headers *@
                    <div class="text-center text-xs font-bold tracking-wider text-gray-400 uppercase">x1</div>
                    <div class="text-center text-xs font-bold tracking-wider text-gray-400 uppercase">x2</div>
                    <div class="text-center text-xs font-bold tracking-wider text-gray-400 uppercase">x3</div>
                    <div class="border-l border-gray-200 pl-4 text-center text-xs font-bold tracking-wider text-gray-800 uppercase">b (RHS)</div>

                    @* Row 1 *@
                    <input @bind="a11" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <input @bind="a12" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <input @bind="a13" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <div class="border-l border-gray-200 pl-4">
                        <input @bind="b1" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm font-bold focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    </div>

                    @* Row 2 *@
                    <input @bind="a21" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <input @bind="a22" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <input @bind="a23" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <div class="border-l border-gray-200 pl-4">
                        <input @bind="b2" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm font-bold focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    </div>

                    @* Row 3 *@
                    <input @bind="a31" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <input @bind="a32" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <input @bind="a33" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    <div class="border-l border-gray-200 pl-4">
                        <input @bind="b3" type="number" class="w-full rounded bg-gray-50 px-4 py-3 text-center font-mono text-sm font-bold focus:bg-blue-50 focus:ring-1 focus:ring-blue-400 focus:outline-none" />
                    </div>
                </div>
            </div>

            @* Secondary Settings (Initial Guesses) *@
            <div class="mt-8 border-t border-gray-100 pt-8">
                <div class="space-y-4 md:w-1/2">
                    <label class="block text-xs font-bold tracking-widest text-gray-500 uppercase">
                        Initial Guesses <span class="text-red-400">*</span>
                    </label>
                    <div class="flex gap-4">
                        <div class="flex w-full items-center gap-2 border-b border-gray-200 pb-1">
                            <span class="font-mono text-sm text-gray-400">x1=</span>
                            <input @bind="x1Initial" type="number" class="w-full bg-transparent text-center font-mono text-sm focus:outline-none" />
                        </div>
                        <div class="flex w-full items-center gap-2 border-b border-gray-200 pb-1">
                            <span class="font-mono text-sm text-gray-400">x2=</span>
                            <input @bind="x2Initial" type="number" class="w-full bg-transparent text-center font-mono text-sm focus:outline-none" />
                        </div>
                        <div class="flex w-full items-center gap-2 border-b border-gray-200 pb-1">
                            <span class="font-mono text-sm text-gray-400">x3=</span>
                            <input @bind="x3Initial" type="number" class="w-full bg-transparent text-center font-mono text-sm focus:outline-none" />
                        </div>
                    </div>
                </div>
            </div>

            @* --- ACTION BUTTONS --- *@
            <div class="mt-10 flex justify-end gap-4 border-t border-gray-100 pt-6">
                <button @onclick="ClearInputs" 
                        class="rounded-lg px-6 py-2.5 text-xs font-bold tracking-widest text-gray-500 transition-all hover:bg-gray-50 hover:text-gray-900">
                    CLEAR
                </button>
                <button @onclick="Calculate" 
                        class="rounded-lg bg-slate-900 px-8 py-2.5 text-xs font-bold tracking-widest text-white shadow-md transition-all hover:bg-blue-600 hover:shadow-lg active:translate-y-0.5">
                    CALCULATE
                </button>
            </div>
        </div>

        @* --- RESULTS AREA --- *@
        @if (isCalculated)
        {
            <div class="animate-fade-in-up mt-8">
                
                @if (divisionByZeroError)
                {
                    <div class="flex items-center gap-3 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
                        <i class="fa-solid fa-circle-exclamation text-red-500"></i>
                        <span class="text-sm font-medium">
                            Calculation failed: Division by zero. A diagonal element (a11, a22, or a33) is zero. Please rearrange your rows!
                        </span>
                    </div>
                }
                else
                {
                    @* Display Rearranged Formulas *@
                    <div class="mb-6 rounded-xl border border-blue-100 bg-blue-50/50 p-6 shadow-sm">
                        <h3 class="mb-4 text-xs font-bold tracking-widest text-blue-800 uppercase">Rearranged Equations Used</h3>
                        <div class="flex flex-col gap-2 font-mono text-sm text-gray-700">
                            <div>x1 = ( @b1 - (@a12)x2 - (@a13)x3 ) / @a11</div>
                            <div>x2 = ( @b2 - (@a21)x1 - (@a23)x3 ) / @a22</div>
                            <div>x3 = ( @b3 - (@a31)x1 - (@a32)x2 ) / @a33</div>
                        </div>
                    </div>

                    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-center text-sm">
                                <thead class="bg-gray-50 text-xs font-bold tracking-wider text-gray-500 uppercase">
                                    <tr>
                                        <th class="px-6 py-4">Iter</th>
                                        <th class="px-6 py-4 text-blue-600">x1</th>
                                        <th class="px-6 py-4 text-blue-600">x2</th>
                                        <th class="px-6 py-4 text-blue-600">x3</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @{
                                        var last = iterations.Last();
                                        bool exactRootFoundInTable = false;
                                    }

                                    @foreach (var iter in iterations)
                                    {
                                        bool isExactRoot = iter.IsStable;
                                        bool isLastRow = iter.Index == last.Index;
                                        
                                        bool isHighlight = (isExactRoot && !exactRootFoundInTable) || (!exactRootFoundInTable && isLastRow && !diverged);
                                        if (isExactRoot) exactRootFoundInTable = true;

                                        <tr class="transition-colors hover:bg-blue-50/30 @(isHighlight ? "bg-blue-600 text-white hover:bg-blue-700" : "text-gray-600")">
                                            <td class="px-6 py-3 font-mono">@iter.Index</td>
                                            <td class="px-6 py-3 font-mono font-bold @(isHighlight ? "text-white" : "text-blue-600")">@iter.X1.ToString("0.####")</td>
                                            <td class="px-6 py-3 font-mono font-bold @(isHighlight ? "text-white" : "text-blue-600")">@iter.X2.ToString("0.####")</td>
                                            <td class="px-6 py-3 font-mono font-bold @(isHighlight ? "text-white" : "text-blue-600")">@iter.X3.ToString("0.####")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    @* Result Summary Footer *@
                    @if (diverged)
                    {
                        <div class="mt-4 flex items-center gap-3 rounded-lg border border-red-200 bg-red-50 p-4 text-red-800">
                            <i class="fa-solid fa-circle-exclamation text-red-500"></i>
                            <span class="text-sm font-medium">
                                Iteration stopped. The method is diverging rapidly. Check if your equations are Diagonally Dominant!
                            </span>
                        </div>
                    }
                    else if (!exactRootFoundInTable)
                    {
                        <div class="mt-4 flex items-center gap-3 rounded-lg border border-amber-200 bg-amber-50 p-4 text-amber-800">
                            <i class="fa-solid fa-triangle-exclamation text-amber-500"></i>
                            <span class="text-sm font-medium">Stopped after 1000 iterations without reaching perfect stability. The highlighted root is approximate.</span>
                        </div>
                    }
                }
            </div>
        }
    </SolveSection>
</Method>


@code {
    // Matrix Inputs
    private double? a11, a12, a13, b1;
    private double? a21, a22, a23, b2;
    private double? a31, a32, a33, b3;

    // Initial Guesses
    private double? x1Initial, x2Initial, x3Initial;

    // State
    private bool isCalculated = false;
    private bool divisionByZeroError = false;
    private bool diverged = false;
    
    private List<IterationResult> iterations = new();

    protected override void OnInitialized()
    {
        ClearInputs();
    }

    private void LoadExample()
    {
        // Exact numbers from your slide
        a11 = 3; a12 = -0.1; a13 = -0.2; b1 = 7.85;
        a21 = 0.1; a22 = 7; a23 = -0.3; b2 = -19.3;
        a31 = 0.3; a32 = -0.2; a33 = 10; b3 = 71.4;

        x1Initial = 0;
        x2Initial = 0;
        x3Initial = 0;
        
        isCalculated = false;
        ToastService.ShowSuccess("Slide example loaded!");
    }

    private void ClearInputs()
    {
        a11 = null; a12 = null; a13 = null; b1 = null;
        a21 = null; a22 = null; a23 = null; b2 = null;
        a31 = null; a32 = null; a33 = null; b3 = null;

        x1Initial = null; x2Initial = null; x3Initial = null;
        
        isCalculated = false;
        iterations.Clear();
    }

    private void Calculate()
    {
        if (a11 == null || a12 == null || a13 == null || b1 == null ||
            a21 == null || a22 == null || a23 == null || b2 == null ||
            a31 == null || a32 == null || a33 == null || b3 == null ||
            x1Initial == null || x2Initial == null || x3Initial == null)
        {
            ToastService.ShowError("Please fill in all coefficients, RHS constants, and initial guesses.");
            return;
        }

        // Requires non-zero diagonal elements
        if (Math.Abs(a11.Value) < 1e-15 || Math.Abs(a22.Value) < 1e-15 || Math.Abs(a33.Value) < 1e-15)
        {
            divisionByZeroError = true;
            isCalculated = true;
            return;
        }

        isCalculated = true;
        divisionByZeroError = false;
        diverged = false;
        iterations.Clear();

        double x1Curr = x1Initial.Value;
        double x2Curr = x2Initial.Value;
        double x3Curr = x3Initial.Value;

        // Iteration 0
        iterations.Add(new IterationResult
        {
            Index = 0,
            X1 = x1Curr,
            X2 = x2Curr,
            X3 = x3Curr,
            IsStable = false
        });

        try
        {
            bool keepIterating = true;
            int i = 1;

            while (keepIterating)
            {
                // Slide-Specific Logic: Immediate substitution mid-row (mimicking your slide's table)
                double x1Next = (b1.Value - (a12.Value * x2Curr) - (a13.Value * x3Curr)) / a11.Value;
                double x2Next = (b2.Value - (a21.Value * x1Next) - (a23.Value * x3Curr)) / a22.Value;
                double x3Next = (b3.Value - (a31.Value * x1Next) - (a32.Value * x2Next)) / a33.Value;

                // Stop if difference is less than 0.0001
                double diff1 = Math.Abs(x1Next - x1Curr);
                double diff2 = Math.Abs(x2Next - x2Curr);
                double diff3 = Math.Abs(x3Next - x3Curr);
                bool isStable = diff1 < 0.0001 && diff2 < 0.0001 && diff3 < 0.0001;

                iterations.Add(new IterationResult
                {
                    Index = i,
                    X1 = x1Next,
                    X2 = x2Next,
                    X3 = x3Next,
                    IsStable = isStable
                });

                // STOPPING LOGIC
                bool isDiverging = double.IsInfinity(x1Next) || double.IsNaN(x1Next) || Math.Abs(x1Next) > 1e10;

                if (isDiverging)
                {
                    diverged = true;
                    keepIterating = false;
                }
                else if (isStable)
                {
                    keepIterating = false;
                }
                else if (i >= 1000) 
                {
                    keepIterating = false;
                }

                // Shift values for the next round
                x1Curr = x1Next;
                x2Curr = x2Next;
                x3Curr = x3Next;
                i++;
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"An unexpected error occurred: {ex.Message}");
        }
    }

    public class IterationResult
    {
        public int Index { get; set; }
        public double X1 { get; set; }
        public double X2 { get; set; }
        public double X3 { get; set; }
        public bool IsStable { get; set; }
    }
}